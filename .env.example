# Anthropic API Key — للتقرير المخصص ودليل الأفكار (يعمل بدونه عبر fallback جاهز)
ANTHROPIC_API_KEY=your_api_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.saudimillion.com

# Google Analytics — اتركه فارغاً لتعطيل التتبع، السكريبت لن يُحمَّل أصلاً بدونه
NEXT_PUBLIC_GA_ID=

# TikTok Pixel — اتركه فارغاً لتعطيل التتبع، السكريبت لن يُحمَّل أصلاً بدونه
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
